PULSENOTE_BACKEND_URL=https://pulsenote.onrender.com
PULSENOTE_APP_TOKEN=use-the-same-secret-as-pulsenote-render-app-client-token

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Clé service-role (écritures serveur des webhooks — NE JAMAIS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Stripe (mode test pour commencer)
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# price_id des 3 abonnements (créés dans Stripe → Products)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_CREATOR=price_xxx
STRIPE_PRICE_STUDIO=price_xxx

# URL publique de l'app (redirections Checkout + webhook)
APP_URL=http://localhost:8093

# Internal image cost attributed to each generation for per-user margin reporting.
OPENAI_IMAGE_COST_CENTS=17

# E-mails autorisés à voir les tableaux administrateur (séparés par virgule)
ADMIN_EMAILS=owner@example.com
